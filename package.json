{
  "name": "auros-backend",
  "version": "2.2.0",
  "description": "Auros — AI-powered procurement reconciliation and data cleaning platform",
  "main": "server.js",
  "scripts": {
    "start"         : "node server.js",
    "dev"           : "nodemon server.js",
    "worker"        : "node queues/worker.js",
    "worker:dev"    : "nodemon queues/worker.js",
    "test"          : "echo \"Error: no test specified\" && exit 1",
    "lint"          : "eslint . --ext .js",
    "py:install"    : "pip install -r python/requirements.txt --break-system-packages",
    "py:check"      : "python3 python/data_engine.py < /dev/null || true"
  },
  "dependencies": {
    "@google/generative-ai"  : "^0.24.1",
    "bcryptjs"               : "^2.4.3",
    "bullmq"                 : "^5.0.0",
    "cors"                   : "^2.8.6",
    "dotenv"                 : "^17.4.2",
    "express"                : "^5.2.1",
    "express-rate-limit"     : "^7.5.0",
    "helmet"                 : "^8.0.0",
    "ioredis"                : "^5.3.2",
    "multer"                 : "^2.1.1",
    "openai"                 : "^6.35.0",
    "papaparse"              : "^5.5.3",
    "twilio"                 : "^6.0.2",
    "xlsx"                   : "^0.18.5",
    "zod"                    : "^3.25.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.2",
    "eslint" : "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}